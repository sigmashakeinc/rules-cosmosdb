# cosmosdb_write_safety.rules
# Technology: cosmosdb | Capability: write

rule cosmosdb-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "UNSAFE_cosmosdb_PATTERN"
  MESSAGE "Blocked an unsafe pattern in cosmosdb. Use the recommended best practices for 2025/2026."
}

rule cosmosdb-force-updated-api {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path GLOB "**/*" AND content CONTAINS "OLD_cosmosdb_API"
  MESSAGE "You are using an outdated API for cosmosdb. Please upgrade to the newer API."
}
